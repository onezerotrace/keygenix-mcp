# Keygenix MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# API Auth private key (secp256k1 hex) — authenticates all API requests
# Generate with: npx keygenix-mcp keygen  (or node -e "require('./dist/tools/keygen').handleKeygen()|console.log")
KEYGENIX_API_PRIV_KEY=

# AuthKey private key (secp256k1 hex) — authorizes sign/export operations
# Generate separately from API Auth key
KEYGENIX_AUTH_PRIV_KEY=

# Organization code — from keygenix.pro dashboard
KEYGENIX_ORG_CODE=

# Wallet code — from keygenix.pro dashboard
KEYGENIX_WALLET_CODE=
